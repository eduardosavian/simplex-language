func toString(_: int) -> string {}
func print(_: string){}

func fizzbuzz(max: int){
	for i: int = 0; i < max; i = i + 1 {
		if i % 3 == 0 {
			print("Fizz");
		}
		else if i % 5 == 0 {
			print("Buzz");
		}
		else {
			print(toString(i));
		}

	}
}

func main() {
	a: int = 200;
	b: int = 2;
	c: int = a / b;
}


